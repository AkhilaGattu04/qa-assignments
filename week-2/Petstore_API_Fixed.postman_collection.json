  "item": [
    {
      "name": "Pet",
      "item": [
        {
          "name": "Task1 - Add Pet",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
            "pm.test(\"Pet name is Gani\", function () { const j = pm.response.json(); pm.expect(j.name).to.eql(\"Gani\"); });",
            "pm.test(\"Pet ID is 101\", function () { const j = pm.response.json(); pm.expect(j.id).to.eql(101); });",
            "pm.test(\"Response time is under 3000ms\", function () { pm.expect(pm.response.responseTime).to.be.below(3000); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "api_key", "value": "{{api_key}}", "type": "text" }, { "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": { "mode": "raw", "raw": "{\n  \"id\": 101,\n  \"name\": \"Gani\",\n  \"status\": \"available\",\n  \"photoUrls\": [\"https://example.com/dog.jpg\"],\n  \"category\": { \"id\": 1, \"name\": \"Dogs\" }\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/pet", "host": ["{{base_url}}"], "path": ["pet"] }
          }
        },
        {
          "name": "Task2 - Find Pets by Valid Status",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
            "pm.test(\"Response is an array\", function () { pm.expect(pm.response.json()).to.be.an(\"array\"); });",
            "pm.test(\"Each pet has name and status\", function () { const j = pm.response.json(); j.slice(0,5).forEach(function(p){ pm.expect(p).to.have.property(\"name\"); pm.expect(p).to.have.property(\"status\"); }); });"
          ]}}],
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/pet/findByStatus?status=available", "host": ["{{base_url}}"], "path": ["pet","findByStatus"], "query": [{ "key": "status", "value": "available" }] }
          }
        },
        {
          "name": "Task2 - Find Pets by Invalid Status (Negative)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Invalid status returns 200 empty array or 400\", function () { const code = pm.response.code; if(code === 200){ pm.expect(pm.response.json()).to.be.an(\"array\"); } else { pm.expect(code).to.eql(400); } });"
          ]}}],
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/pet/findByStatus?status=unknown", "host": ["{{base_url}}"], "path": ["pet","findByStatus"], "query": [{ "key": "status", "value": "unknown" }] }
          }
        },
        {
          "name": "Task3 - Get Pet by ID",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
            "pm.test(\"Pet ID is 101\", function () { pm.expect(pm.response.json().id).to.eql(101); });",
            "pm.test(\"Pet name is Gani\", function () { pm.expect(pm.response.json().name).to.eql(\"Gani\"); });"
          ]}}],
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/pet/{{pet_id}}", "host": ["{{base_url}}"], "path": ["pet","{{pet_id}}"] }
          }
        },
        {
          "name": "Task3 - Get Pet Not Found (Negative)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
