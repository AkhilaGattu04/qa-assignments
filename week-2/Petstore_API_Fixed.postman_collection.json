        {
          "name": "Task4 - Update Pet",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
            "pm.test(\"Pet name is updated\", function () { pm.expect(pm.response.json().name).to.eql(\"Gani Updated\"); });",
            "pm.test(\"Pet status is pending\", function () { pm.expect(pm.response.json().status).to.eql(\"pending\"); });",
            "pm.test(\"Pet ID is still 101\", function () { pm.expect(pm.response.json().id).to.eql(101); });"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "api_key", "value": "{{api_key}}", "type": "text" }, { "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": { "mode": "raw", "raw": "{\n  \"id\": 101,\n  \"name\": \"Gani Updated\",\n  \"status\": \"pending\",\n  \"photoUrls\": [\"https://example.com/dog.jpg\"],\n  \"category\": { \"id\": 1, \"name\": \"Dogs\" }\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/pet", "host": ["{{base_url}}"], "path": ["pet"] }
          }
        },
        {
          "name": "Task5 - Delete Pet",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
            "pm.test(\"Response confirms deletion\", function () { pm.expect(pm.response.json().message).to.eql(\"101\"); });"
          ]}}],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "api_key", "value": "{{api_key}}", "type": "text" }],
            "url": { "raw": "{{base_url}}/pet/{{pet_id}}", "host": ["{{base_url}}"], "path": ["pet","{{pet_id}}"] }
