          "name": "Task10 - Create User",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
            "pm.test(\"User created successfully\", function () { pm.expect(pm.response.json().message).to.exist; });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": { "mode": "raw", "raw": "{\n  \"id\": 301,\n  \"username\": \"testuser01\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Pass@123\",\n  \"phone\": \"9876543210\",\n  \"userStatus\": 1\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/user", "host": ["{{base_url}}"], "path": ["user"] }
          }
        },
        {
          "name": "Task11 - Login",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
            "pm.test(\"Response contains logged in message\", function () { pm.expect(pm.response.json().message).to.include(\"logged in\"); });",
            "pm.test(\"X-Rate-Limit header exists\", function () { pm.expect(pm.response.headers.get(\"X-Rate-Limit\")).to.exist; });",
            "pm.test(\"X-Expires-After header exists\", function () { pm.expect(pm.response.headers.get(\"X-Expires-After\")).to.exist; });"
          ]}}],
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/user/login?username={{username}}&password=Pass@123", "host": ["{{base_url}}"], "path": ["user","login"], "query": [{ "key": "username", "value": "{{username}}" }, { "key": "password", "value": "Pass@123" }] }
          }
